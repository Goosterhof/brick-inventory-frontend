{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "import", "unicorn", "promise", "vue", "vitest"],
    "env": {"browser": true, "es2024": true},
    "ignorePatterns": ["dist/**", "dist-ssr/**", "coverage/**", "node_modules/**"],
    "rules": {
        // Core rules
        "no-console": "error",
        "prefer-const": "error",
        "eqeqeq": "error",
        "no-var": "error",
        "no-undef": "off", // handled by TypeScript
        "no-unused-vars": "off", // handled by @typescript-eslint/no-unused-vars
        "no-debugger": "error",
        "no-empty": "error",
        "no-duplicate-imports": "off", // import/no-duplicates handles this better with type imports
        "no-self-compare": "error",
        "no-template-curly-in-string": "error",
        "no-unreachable": "error",
        "no-unsafe-negation": "error",
        "no-return-await": "error",
        "no-throw-literal": "error",
        "radix": "error",
        "no-restricted-imports": [
            "error",
            {
                "patterns": [
                    {
                        "regex": "\\.\\./apps/|\\.\\./(\\.\\./)*(apps/)",
                        "message": "Use @app/ or @shared/ aliases instead of relative paths crossing module boundaries."
                    },
                    {
                        "regex": "\\.\\./shared/|\\.\\./(\\.\\./)*(shared/)",
                        "message": "Use @shared/ alias instead of relative paths crossing module boundaries."
                    },
                    {
                        "regex": "^@/apps/",
                        "message": "Use @app/ alias instead of @/apps/. Direct app references bypass the multi-app build boundary."
                    }
                ]
            }
        ],

        // TypeScript rules
        "@typescript-eslint/no-non-null-assertion": "error",
        "@typescript-eslint/no-explicit-any": "error",
        "@typescript-eslint/no-unused-vars": "error",
        "@typescript-eslint/no-empty-interface": "error",
        "@typescript-eslint/prefer-as-const": "error",
        "@typescript-eslint/ban-ts-comment": "error",
        "@typescript-eslint/no-duplicate-enum-values": "error",

        // Type-aware rules (require --type-aware flag)
        "typescript/no-floating-promises": "error",
        "typescript/no-misused-promises": "error",
        "typescript/await-thenable": "error",
        "typescript/no-for-in-array": "error",
        "typescript/only-throw-error": "error",
        "typescript/no-unsafe-argument": "error",
        "typescript/no-unsafe-assignment": "error",
        "typescript/no-unsafe-call": "error",
        "typescript/no-unsafe-member-access": "error",
        "typescript/no-unsafe-return": "error",
        "typescript/no-unnecessary-type-assertion": "error",
        "typescript/no-redundant-type-constituents": "error",
        "typescript/prefer-optional-chain": "warn",
        "typescript/prefer-nullish-coalescing": "warn",
        "typescript/switch-exhaustiveness-check": "error",
        "typescript/consistent-type-imports": "error",
        "typescript/no-import-type-side-effects": "error",
        // Use the type-aware version of require-await; the core rule was removed from the general rules to avoid duplicate configuration.
        "typescript/require-await": "warn",

        // Import rules
        "import/no-duplicates": "error",
        "import/first": "error",
        "import/no-self-import": "error",
        "import/no-cycle": "error",
        "import/no-mutable-exports": "error",
        "import/no-named-default": "error",
        "import/no-default-export": "off", // Vue components use default exports

        // Unicorn rules - modern JS best practices
        "unicorn/no-array-for-each": "error",
        "unicorn/prefer-array-some": "warn",
        "unicorn/prefer-includes": "warn",
        "unicorn/prefer-string-starts-ends-with": "warn",
        "unicorn/no-null": "off", // null is fine in this project
        "unicorn/prefer-array-flat": "warn",
        "unicorn/prefer-array-flat-map": "warn",
        "unicorn/prefer-number-properties": "warn",
        "unicorn/prefer-optional-catch-binding": "warn",
        "unicorn/throw-new-error": "error",
        "unicorn/no-useless-spread": "error",
        "unicorn/no-nested-ternary": "error",
        "unicorn/prefer-node-protocol": "warn",
        "unicorn/prefer-ternary": "off", // can reduce readability
        "unicorn/no-array-push-splice": "warn",
        "unicorn/prefer-spread": "warn",
        "unicorn/no-lonely-if": "warn",

        // Promise rules
        "promise/no-return-wrap": "error",
        "promise/catch-or-return": "error",
        "promise/no-nesting": "error",
        "promise/param-names": "error",

        // Vue rules
        "vue/no-arrow-functions-in-watch": "error",
        "vue/no-deprecated-destroyed-lifecycle": "error",
        "vue/no-export-in-script-setup": "error",
        "vue/no-lifecycle-after-await": "error",
        "vue/prefer-import-from-vue": "error",
        "vue/no-required-prop-with-default": "error",
        "vue/require-typed-ref": "error",
        "vue/no-ref-as-operand": "error",
        "vue/no-dupe-keys": "error",
        "vue/no-template-shadow": "warn",

        // Vitest rules
        "vitest/no-conditional-tests": "error",
        "vitest/no-import-node-test": "error",
        "vitest/consistent-test-filename": ["warn", {"pattern": ".*\\.spec\\.ts$"}],
        "vitest/prefer-to-be-object": "warn"
    },
    "overrides": [
        {"files": ["*.vue"], "rules": {"no-undef": "off"}},
        {"files": ["src/shared/services/storage.ts"], "rules": {"no-console": "off"}},
        {"files": ["src/tests/**"], "rules": {"no-restricted-imports": "off"}},
        {
            "files": ["src/shared/**"],
            "rules": {
                "no-restricted-imports": [
                    "error",
                    {
                        "patterns": [
                            {
                                "regex": "\\.\\./apps/|\\.\\./(\\.\\./)*(apps/)",
                                "message": "Use @app/ or @shared/ aliases instead of relative paths crossing module boundaries."
                            },
                            {
                                "regex": "\\.\\./shared/|\\.\\./(\\.\\./)*(shared/)",
                                "message": "Use @shared/ alias instead of relative paths crossing module boundaries."
                            },
                            {
                                "regex": "^@/apps/",
                                "message": "Use @app/ alias instead of @/apps/. Direct app references bypass the multi-app build boundary."
                            },
                            {
                                "regex": "^@app/",
                                "message": "Shared code must not import from @app/. Shared modules must remain app-agnostic."
                            }
                        ]
                    }
                ]
            }
        },
        {"files": ["src/**/*.ts"], "rules": {"import/no-default-export": "error"}}
    ]
}
