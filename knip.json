{
    "$schema": "https://unpkg.com/knip@latest/schema.json",
    "entry": [
        "src/apps/*/main.ts",
        "src/apps/*/services/index.ts",
        "src/apps/*/domains/*/index.ts",
        "src/tests/**/*.spec.ts",
        "src/tests/browser/setup.ts",
        "src/tests/integration/setup.ts"
    ],
    "project": ["src/**/*.ts", "src/**/*.vue"],
    "paths": {"@/*": ["src/*"], "@shared/*": ["src/shared/*"], "@app/*": ["src/apps/families/*", "src/apps/admin/*"]},
    "ignore": ["src/**/*.d.ts", "vitest.config.ts", "vitest.browser.config.ts", "vitest.integration.config.ts"],
    "ignoreDependencies": ["@typescript/native-preview", "@vitest/browser"]
}
