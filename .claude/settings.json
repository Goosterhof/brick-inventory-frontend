{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/guard-generated-files.sh",
                        "timeout": 5,
                        "statusMessage": "Checking for generated file edits..."
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/guard-destructive-git.sh",
                        "if": "Bash(git *)",
                        "timeout": 5,
                        "statusMessage": "Checking for destructive git commands..."
                    },
                    {
                        "type": "command",
                        "if": "Bash(git commit:*)",
                        "command": "npx oxfmt --write .",
                        "timeout": 30,
                        "statusMessage": "Auto-formatting before commit..."
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/check-formatting.sh",
                        "timeout": 15,
                        "statusMessage": "Checking formatting..."
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "matcher": "startup",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/session-start-check.sh",
                        "timeout": 10,
                        "statusMessage": "Checking build environment..."
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/minutes-nudge.sh",
                        "timeout": 5,
                        "statusMessage": "Checking minutes..."
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/journal-nudge.sh",
                        "timeout": 5,
                        "statusMessage": "Checking for unfiled construction journals..."
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "if [ -f MINUTES.md ] && ! git diff --quiet MINUTES.md 2>/dev/null || ([ -f MINUTES.md ] && ! git ls-files --error-unmatch MINUTES.md >/dev/null 2>&1); then git add MINUTES.md && git commit -m 'docs: auto-commit session minutes'; fi",
                        "timeout": 15,
                        "statusMessage": "Auto-committing minutes..."
                    }
                ]
            }
        ]
    }
}
