{
    "name": "lego-storage-frontend",
    "version": "1.0.0",
    "description": "Vue 3 multi-app monorepo for managing LEGO brick inventory",
    "author": "Gerard Oosterhof",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Goosterhof/lego-storage-frontend.git"
    },
    "homepage": "https://github.com/Goosterhof/lego-storage-frontend#readme",
    "keywords": [
        "lego",
        "inventory",
        "vue",
        "vue3",
        "typescript",
        "vite"
    ],
    "private": false,
    "type": "module",
    "scripts": {
        "build": "run-p type-check \"build:families {@}\" \"build:admin {@}\" --",
        "build:admin": "cross-env APP_NAME=admin vite build",
        "build:families": "cross-env APP_NAME=families vite build",
        "dev": "cross-env APP_NAME=families vite",
        "dev:admin": "cross-env APP_NAME=admin vite",
        "dev:families": "cross-env APP_NAME=families vite",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint --type-aware",
        "preview": "cross-env APP_NAME=families vite preview",
        "test:coverage": "vitest run --coverage",
        "test:unit": "vitest",
        "type-check": "vue-tsc --build"
    },
    "dependencies": {
        "axios": "^1.7.9",
        "string-ts": "^2.3.1",
        "vue": "^3.5.26",
        "vue-router": "^4.6.4"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.4",
        "@types/jsdom": "^27.0.0",
        "@types/node": "^24.10.9",
        "@typescript/native-preview": "^7.0.0-dev.20260129.1",
        "@unocss/reset": "^66.6.0",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vitest/coverage-v8": "^4.0.18",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.8.1",
        "axios-mock-adapter": "^2.1.0",
        "cross-env": "^10.1.0",
        "jiti": "^2.6.1",
        "jsdom": "^27.4.0",
        "npm-run-all2": "^8.0.4",
        "oxfmt": "^0.27.0",
        "oxlint": "^1.42.0",
        "oxlint-tsgolint": "^0.11.3",
        "rolldown-vite": "^7.3.1",
        "typescript": "~5.9.3",
        "unocss": "^66.6.0",
        "vite": "^7.3.1",
        "vite-plugin-oxlint": "^1.6.0",
        "vite-plugin-vue-devtools": "^8.0.5",
        "vitest": "^4.0.17",
        "vue-component-type-helpers": "^3.2.4",
        "vue-tsc": "^3.2.2"
    },
    "engines": {
        "node": ">=24"
    }
}
