{
    "name": "lego-storage-frontend",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "run-p type-check \"build-only {@}\" --",
        "build-only": "vite build",
        "dev": "vite",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint",
        "preview": "vite preview",
        "test:coverage": "vitest run --coverage",
        "test:unit": "vitest",
        "type-check": "vue-tsc --build"
    },
    "dependencies": {
        "axios": "^1.7.9",
        "string-ts": "^2.3.1",
        "vue": "^3.5.26",
        "vue-router": "^4.6.4"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.4",
        "@types/jsdom": "^27.0.0",
        "@types/node": "^24.10.9",
        "@unocss/reset": "^66.6.0",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vitest/coverage-v8": "^4.0.18",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.8.1",
        "axios-mock-adapter": "^2.1.0",
        "jiti": "^2.6.1",
        "jsdom": "^27.4.0",
        "npm-run-all2": "^8.0.4",
        "oxfmt": "^0.27.0",
        "oxlint": "^1.42.0",
        "rolldown-vite": "^7.3.1",
        "typescript": "~5.9.3",
        "unocss": "^66.6.0",
        "vite": "^7.3.1",
        "vite-plugin-oxlint": "^1.6.0",
        "vite-plugin-vue-devtools": "^8.0.5",
        "vitest": "^4.0.17",
        "vue-component-type-helpers": "^3.2.4",
        "vue-tsc": "^3.2.2"
    },
    "engines": {
        "node": ">=24"
    }
}
